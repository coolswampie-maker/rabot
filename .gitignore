# dependencies
/node_modules
/.pnp
.pnp.js

# next
/.next/
/out/
next-env.d.ts
*.tsbuildinfo

# production
/build

# env / secrets — NEVER commit these
.env
.env.local
.env*.local

# database
*.db

# local embedded Postgres data (dev only)
/.pgdata/

# raw asset drops in repo root (kept on disk, not committed — wired copies live in public/)
/*.jpg
/*.jpeg
/*.png
/*.webp
/*.pdf

# uploads (local dev media storage)
/public/uploads/*
!/public/uploads/.gitkeep

# misc
.DS_Store
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*
/coverage

# editor
.vscode/*
!.vscode/extensions.json
.idea
