# ------------------------------------------------------------------
# Copy this file to `.env` and fill in real values.
# NEVER commit `.env` — it is git-ignored.
# ------------------------------------------------------------------

# Database (PostgreSQL). Matches docker-compose.yml defaults for local dev.
DATABASE_URL="postgresql://rudn:rudn@localhost:5432/rudn?schema=public"

# Auth — secret used to sign admin session JWTs. Generate a long random string:
#   openssl rand -base64 48
AUTH_SECRET="change-me-to-a-long-random-string-min-32-chars"

# First admin user, created by `npm run db:seed` / `npm run admin:create`.
ADMIN_EMAIL="admin@rudn-business.example"
ADMIN_PASSWORD="change-me-strong-password"
ADMIN_NAME="Site Administrator"

# ------------------------------------------------------------------
# Handover ("Этап 1") deployment: public site + lead collection only.
# ------------------------------------------------------------------
# Professional content-management admin (/admin). Leave UNSET to run the
# handover build (no CMS — /admin returns 404). Set to "1" only on the
# internal build where the full editor is wanted.
ENABLE_CMS=""

# Token for the standalone leads viewer (/leads). Min 8 chars. Open leads via
# /leads/auth?token=<this>, or enter it once on the /leads page.
LEADS_TOKEN="change-me-to-a-long-random-token"

# Email notifications for new submissions (optional — skipped if SMTP_HOST or
# LEADS_NOTIFY_EMAIL is empty). Works with any SMTP provider (Yandex, Mail.ru…).
LEADS_NOTIFY_EMAIL=""          # where new-lead notifications are sent
SMTP_HOST=""                   # e.g. smtp.yandex.ru
SMTP_PORT="587"                # 587 (STARTTLS) or 465 (SSL)
SMTP_SECURE=""                 # "1" for port 465, otherwise leave empty
SMTP_USER=""                   # SMTP username / mailbox
SMTP_PASS=""                   # SMTP password / app password
SMTP_FROM=""                   # From address (defaults to SMTP_USER)

# Public site URL (used for canonical URLs, sitemap, Open Graph).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Brand subdomains (production). In dev these fall back to /accelerator and /research routes.
NEXT_PUBLIC_ACCELERATOR_HOST="accelerator.localhost:3000"
NEXT_PUBLIC_RESEARCH_HOST="research.localhost:3000"

# Media storage. driver = "local" (dev) | "s3" (production, S3-compatible).
MEDIA_DRIVER="local"
MEDIA_LOCAL_DIR="public/uploads"
MEDIA_PUBLIC_PREFIX="/uploads"

# S3-compatible storage (only needed when MEDIA_DRIVER=s3).
S3_ENDPOINT=""
S3_REGION="us-east-1"
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_PUBLIC_BASE_URL=""
